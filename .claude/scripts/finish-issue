#!/usr/bin/env bash
# Usage: finish-issue ["PR body — what changed and why"]
# Run from inside the worktree when work is done.
# tests → push → PR (Closes #N + body) → wait for CI → merge → remove worktree.
# If CI is red the merge is skipped and the worktree is KEPT — fix and re-run.
# Pass a real body: it is appended under the Closes line. Without one, a fallback
# is generated from the commit list + diffstat.
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner)
BRANCH=$(git branch --show-current)
WORKTREE=$(git rev-parse --show-toplevel)
MAIN_REPO=$(git worktree list | head -1 | awk '{print $1}')
ISSUE_NUM=$(echo "$BRANCH" | grep -oE '[0-9]+' | head -1)

# Run tests if a .Tests.csproj exists
TESTPROJ=$(find . -name "*.Tests.csproj" -maxdepth 4 | head -1)
if [ -n "$TESTPROJ" ]; then
  echo "Running tests: $TESTPROJ"
  dotnet test "$TESTPROJ" -c Release || { echo "Tests failed — fix before merging."; exit 1; }
else
  echo "No test project found — skipping tests."
fi

# Commit if there are changes
git add -A
remind_docs
if ! git diff --cached --quiet; then
  TITLE=$(gh issue view "$ISSUE_NUM" --repo "$REPO" --json title -q .title 2>/dev/null || echo "fix: issue #${ISSUE_NUM}")
  git commit -m "$TITLE"
fi

git push -u origin "$BRANCH"

# Open the PR (or reuse an already-open one), linked to the issue
BODY="${1:-}"
if ! gh pr view --json state -q .state 2>/dev/null | grep -q "OPEN"; then
  gh pr create --fill --base main \
    --body "$(printf 'Closes #%s\n\n%s' "$ISSUE_NUM" "${BODY:-$(pr_body_fallback)}")" >/dev/null
fi
PR_NUM=$(gh pr view --json number -q .number)
echo "PR #$PR_NUM — waiting for CI…"

if ! wait_for_ci "$PR_NUM"; then
  echo ""
  echo "CI is RED on PR #$PR_NUM — NOT merging. Worktree KEPT at:"
  echo "    $WORKTREE"
  echo "Fix the failure there, then re-run finish-issue."
  exit 1
fi

# no --delete-branch: it checks out main *inside the worktree* and dies; delete it after cleanup
gh pr merge "$PR_NUM" --squash
remove_worktree "$WORKTREE" "$MAIN_REPO"
git checkout main -q
git pull origin main -q
git push origin --delete "$BRANCH" 2>/dev/null || true
echo "Done — PR #$PR_NUM merged, worktree removed, main is up to date."
