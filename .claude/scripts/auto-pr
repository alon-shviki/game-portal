#!/usr/bin/env bash
# Usage: auto-pr "PR title"
# Run from inside a worktree created by start-task. Commits, pushes, opens/updates
# the PR, then waits for CI. Removes the worktree ONLY if CI is green; if CI is red
# the worktree is KEPT so you can fix the failure and re-run auto-pr.
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

TITLE="${1:-}"
WORKTREE=$(git rev-parse --show-toplevel)
MAIN_REPO=$(git worktree list | awk 'NR==1{print $1}')
BRANCH=$(git branch --show-current)
IN_WORKTREE=false
[ "$WORKTREE" != "$MAIN_REPO" ] && IN_WORKTREE=true

if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
  echo "auto-pr: no changes, nothing to do"
  exit 0
fi

if [ -z "$BRANCH" ] || [ "$BRANCH" = "main" ]; then
  echo "auto-pr: not on a feature branch — run start-task first"
  exit 1
fi

git add -A
remind_docs
git commit -m "${TITLE:-auto: $(basename "$BRANCH")}"
git push -u origin "$BRANCH"

if gh pr view --json state -q .state 2>/dev/null | grep -q "OPEN"; then
  echo "auto-pr: PR already open, pushed update"
else
  if [ -n "$TITLE" ]; then
    gh pr create --title "$TITLE" --body "Opened by Claude Code." --base main
  else
    gh pr create --fill --base main
  fi
fi

PR_NUM=$(gh pr view --json number -q .number)
echo "Waiting for CI on PR #$PR_NUM…"
if ! wait_for_ci "$PR_NUM"; then
  echo ""
  echo "CI is RED on PR #$PR_NUM — worktree KEPT at:"
  echo "    $WORKTREE"
  echo "Fix the failure there, then re-run: auto-pr \"$TITLE\""
  exit 1
fi

echo "CI green on PR #$PR_NUM."
if $IN_WORKTREE; then
  remove_worktree "$WORKTREE" "$MAIN_REPO"
  git checkout main -q
  echo "Worktree removed. PR #$PR_NUM is green and ready to merge."
fi
